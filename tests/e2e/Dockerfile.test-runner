FROM python:3.12-slim
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY common.py .
COPY test_auth.py .
COPY test_model_routing.py .
COPY test_workload_routing.py .
COPY test_speculative_wake_priority.py .
COPY e2e/get-token.sh /app/e2e/get-token.sh
COPY e2e/run-e2e-tests.sh /app/run-e2e-tests.sh
RUN chmod +x /app/e2e/get-token.sh /app/run-e2e-tests.sh
ENV MOCK_OIDC_URL=http://mock-oidc:9090
CMD ["/app/run-e2e-tests.sh"]
